<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimary"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnMerge"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="@color/colorAccent"
            android:textColor="@color/white"
            android:text="Merge PDFs" />

        <Button
            android:id="@+id/btnSplit"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="@color/colorAccent"
            android:textColor="@color/white"
            android:text="Split PDF" />

        <Button
            android:id="@+id/btnCompress"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="@color/colorAccent"
            android:textColor="@color/white"
            android:text="Compress PDF" />

        <Button
            android:id="@+id/btnConvert"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="@color/colorAccent"
            android:textColor="@color/white"
            android:text="Convert Image to PDF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Image to PDF Settings:"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp"
            android:accessibilityHeading="true" />

        <TextView
            android:id="@+id/tvPageSizeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Page Size Options"
            android:labelFor="@id/spinnerPageSize" />

        <Spinner
            android:id="@+id/spinnerPageSize"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:contentDescription="Select layout output page boundaries scaling rules" />

        <TextView
            android:id="@+id/tvMarginsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Margin Options"
            android:labelFor="@id/spinnerMargins" />
        <Spinner
            android:id="@+id/spinnerMargins"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:contentDescription="Select document safe-zone border padding options" />
    </LinearLayout>
</ScrollView>